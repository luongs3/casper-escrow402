# Copy to `casper-test.env` and fill in. Loaded by the livenet deploy (ODRA_CASPER_LIVENET_ENV=casper-test).

# Path to your funded Testnet secret key (scripts/keygen.sh creates ./keys/secret_key.pem).
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/secret_key.pem

# Testnet node RPC + events. CSPR.cloud is the easy hosted option (free token at https://console.cspr.cloud).
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Free CSPR.cloud API token (sign up at https://console.cspr.cloud). Required for the hosted node above.
CSPR_CLOUD_AUTH_TOKEN=

# Optional: deploy TTL (default 5 min)
# ODRA_CASPER_LIVENET_TTL=
